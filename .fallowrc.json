{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/main.tsx",
    "server.ts",
    "api/workspaces.ts",
    "api/folders.ts",
    "api/documents.ts",
    "api/utils.ts",
    "src/mcp/server.ts"
  ],
  "ignorePatterns": ["src/routeTree.gen.ts", "**/*.d.ts", "__mocks__/**", "docs/**"],
  "ignoreExports": [{ "file": "api/supabaseAdmin.ts", "exports": ["_resetAdminClient"] }],
  "ignoreDependencies": [
    "@codemirror/commands",
    "@codemirror/lang-markdown",
    "@codemirror/language",
    "@codemirror/state",
    "@codemirror/view",
    "@tanstack/router-devtools",
    "@supabase/__mocks__",
    "@tanstack/__mocks__"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unresolved-imports": "error",
    "private-type-leaks": "warn"
  },
  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "threshold": 10
  },
  "health": {
    "maxCyclomatic": 10,
    "maxCognitive": 10
  },
  "audit": {
    "gate": "all",
    "healthBaseline": ".fallow-health-baseline.json",
    "dupesBaseline": ".fallow-dupes-baseline.json"
  }
}
