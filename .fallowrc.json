{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/main.tsx", "server.js"],
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    "**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@codemirror/commands",
    "@codemirror/lang-markdown",
    "@codemirror/language",
    "@codemirror/state",
    "@codemirror/view",
    "@tanstack/router-devtools"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unresolved-imports": "error",
    "private-type-leaks": "warn"
  },
  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "threshold": 10
  },
  "health": {
    "maxCyclomatic": 10,
    "maxCognitive": 10
  },
  "audit": {
    "gate": "all"
  }
}
