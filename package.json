{
  "name": "hiwrld",
  "version": "1.0.0",
  "description": "Realtime Markdown editor — hiwrld.com",
  "homepage": "https://hiwrld.com",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server.ts",
    "start": "tsx server.ts",
    "mcp": "tsx src/mcp/server.ts",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:write": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test && pnpm test:e2e",
    "analyze": "fallow audit",
    "analyze:ci": "fallow audit --format json --quiet"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-router": "^1.169.1",
    "compression": "^1.8.1",
    "dompurify": "^3.2.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.1",
    "markdown-it-github-alerts": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@pandacss/dev": "^1.11.0",
    "@playwright/test": "^1.59.1",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-vite-plugin": "^1.166.47",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "fallow": "^2.62.0",
    "jsdom": "^24.1.3",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^1.6.1"
  }
}
